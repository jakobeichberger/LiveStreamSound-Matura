<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Package Name="LiveStreamSound"
           Manufacturer="Jakob Eichberger"
           Version="0.2.0.0"
           UpgradeCode="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1A010"
           Scope="perMachine"
           Compressed="yes"
           InstallerVersion="500"
           Description="Kabellose Audio-Verteilung für Matura-Prüfungen — eine App, beim Start wählst du senden oder empfangen."
           Keywords="Audio; Streaming; Matura; WPF; LiveStreamSound">

    <MajorUpgrade DowngradeErrorMessage="Eine neuere Version von !(bind.Property.ProductName) ist bereits installiert." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- App icon used in Start Menu, Desktop shortcuts, and Add/Remove Programs. -->
    <Icon Id="app.ico" SourceFile="$(AppPublishDir)Assets\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="app.ico" />

    <!-- Add/Remove-Programs ("Programme und Features") metadata. -->
    <Property Id="ARPHELPLINK" Value="https://github.com/jakobeichberger/LiveStreamSound-Matura" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/jakobeichberger/LiveStreamSound-Matura" />
    <Property Id="ARPURLUPDATEINFO" Value="https://github.com/jakobeichberger/LiveStreamSound-Matura/releases" />
    <Property Id="ARPREADME" Value="https://github.com/jakobeichberger/LiveStreamSound-Matura/blob/main/README.md" />
    <Property Id="ARPCONTACT" Value="jakob@eichberger.tech" />
    <Property Id="ARPCOMMENTS" Value="Synchrone Audio-Verteilung über LAN/WLAN für Matura-Prüfungsräume. Eine Anwendung deckt beide Rollen (Host + Client) über einen Start-Screen ab." />
    <Property Id="ARPSIZE" Value="100000" /><!-- approximate KB to avoid 0 on first install -->
    <!-- Installation allowed in change/remove mode but not in "Modify" (no feature
         tree). Uninstall works normally. -->
    <Property Id="ARPNOMODIFY" Value="1" />

    <Feature Id="Main" Title="LiveStreamSound" Level="1"
             Description="Die LiveStreamSound-Anwendung mit allen Abhängigkeiten, Start-Menü, Desktop-Shortcut, Firewall-Regeln und Windows-Ereignis-Log-Quelle.">
      <Files Include="$(AppPublishDir)**" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
      <ComponentGroupRef Id="AppFirewall" />
      <ComponentGroupRef Id="AppEventLog" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="LiveStreamSound" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="LiveStreamSound" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />

    <ComponentGroup Id="StartMenuShortcuts" Directory="ShortcutFolder">
      <Component Id="StartMenuShortcut" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B301">
        <Shortcut Id="StartMenuShortcutItem"
                  Name="LiveStreamSound"
                  Description="Ton kabellos senden oder empfangen (Matura-Audio-Streaming)"
                  Target="[INSTALLFOLDER]LiveStreamSound.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="app.ico" />
        <RemoveFolder Id="RemoveShortcutFolder" On="uninstall" />
        <!-- HKCU required here: shortcut in per-user-location, ICE38/43/57. -->
        <RegistryValue Root="HKCU" Key="Software\LiveStreamSound" Name="installed_startmenu"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="DesktopShortcuts" Directory="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B303">
        <Shortcut Id="DesktopShortcutItem"
                  Name="LiveStreamSound"
                  Description="Ton kabellos senden oder empfangen (Matura-Audio-Streaming)"
                  Target="[INSTALLFOLDER]LiveStreamSound.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="app.ico" />
        <RegistryValue Root="HKCU" Key="Software\LiveStreamSound" Name="installed_desktop"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      Firewall rules cover all three ports the app can use — machine-wide so
      every account on the laptop benefits:
        TCP 5000 — host control channel (preferred; auto-retries 5001+)
        UDP 5001 — host audio stream source
        TCP 5002 — reserved for future use (idle listener now dynamic)
    -->
    <ComponentGroup Id="AppFirewall" Directory="INSTALLFOLDER">
      <Component Id="AppFirewallRules" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B302" KeyPath="yes">
        <RegistryValue Root="HKLM" Key="Software\LiveStreamSound" Name="firewall"
                       Type="integer" Value="1" />
        <fw:FirewallException Id="LSS_TCP_Control"
                              Name="LiveStreamSound (TCP Control)"
                              Protocol="tcp"
                              Port="5000"
                              Scope="localSubnet"
                              Profile="all" />
        <fw:FirewallException Id="LSS_UDP_Audio"
                              Name="LiveStreamSound (UDP Audio)"
                              Protocol="udp"
                              Port="5001"
                              Scope="localSubnet"
                              Profile="all" />
        <fw:FirewallException Id="LSS_TCP_Invite"
                              Name="LiveStreamSound (TCP Invite)"
                              Protocol="tcp"
                              Port="5002"
                              Scope="localSubnet"
                              Profile="all" />
      </Component>
    </ComponentGroup>

    <!--
      Creates a dedicated Windows Event Log named "LiveStreamSound" plus an
      EventSource of the same name. Warnings / errors from the running app
      land there — no more "only connection errors get logged" surprises —
      and the log shows up separately from "Application" in eventvwr.msc.
    -->
    <ComponentGroup Id="AppEventLog" Directory="INSTALLFOLDER">
      <Component Id="AppEventLogSource" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B305">
        <RegistryValue Root="HKLM"
                       Key="Software\LiveStreamSound"
                       Name="eventlog_registered"
                       Type="integer" Value="1" KeyPath="yes" />
        <util:EventSource Name="LiveStreamSound"
                          Log="LiveStreamSound"
                          EventMessageFile="[SystemFolder]EventCreate.exe" />
      </Component>
    </ComponentGroup>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
  </Package>
</Wix>
