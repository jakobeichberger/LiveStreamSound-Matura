<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="LiveStreamSound"
           Manufacturer="Jakob Eichberger"
           Version="0.2.0.0"
           UpgradeCode="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1A010"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="Eine neuere Version von !(bind.Property.ProductName) ist bereits installiert." />
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- App icon used in Start Menu, Desktop shortcuts, and Add/Remove Programs. -->
    <Icon Id="app.ico" SourceFile="$(AppPublishDir)Assets\app.ico" />
    <Property Id="ARPPRODUCTICON" Value="app.ico" />

    <Feature Id="Main" Title="LiveStreamSound" Level="1">
      <!--
        Self-contained publish folder: app binaries, WPF-UI, NAudio, Concentus,
        Makaretu.Dns, CommunityToolkit.Mvvm, and the .NET 10 runtime host.
      -->
      <Files Include="$(AppPublishDir)**" />
      <ComponentGroupRef Id="StartMenuShortcuts" />
      <ComponentGroupRef Id="DesktopShortcuts" />
      <ComponentGroupRef Id="AppFirewall" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="LiveStreamSound" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ShortcutFolder" Name="LiveStreamSound" />
    </StandardDirectory>

    <!-- CommonDesktopFolder = %PUBLIC%\Desktop, visible for every user on the machine. -->
    <StandardDirectory Id="CommonDesktopFolder" />

    <!-- Start Menu shortcut (per-user KeyPath required by ICE38/43/57 even on per-machine scope). -->
    <ComponentGroup Id="StartMenuShortcuts" Directory="ShortcutFolder">
      <Component Id="StartMenuShortcut" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B301">
        <Shortcut Id="StartMenuShortcutItem"
                  Name="LiveStreamSound"
                  Description="Ton kabellos senden oder empfangen (Matura-Audio-Streaming)"
                  Target="[INSTALLFOLDER]LiveStreamSound.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="app.ico" />
        <RemoveFolder Id="RemoveShortcutFolder" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\LiveStreamSound" Name="installed_startmenu"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- Desktop shortcut, also visible to all users (CommonDesktopFolder). -->
    <ComponentGroup Id="DesktopShortcuts" Directory="CommonDesktopFolder">
      <Component Id="DesktopShortcut" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B303">
        <Shortcut Id="DesktopShortcutItem"
                  Name="LiveStreamSound"
                  Description="Ton kabellos senden oder empfangen (Matura-Audio-Streaming)"
                  Target="[INSTALLFOLDER]LiveStreamSound.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="app.ico" />
        <RegistryValue Root="HKCU" Key="Software\LiveStreamSound" Name="installed_desktop"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!--
      Firewall rules cover all three ports the app uses — machine-wide so every user
      account on the laptop benefits:
        TCP 5000 — host control channel
        UDP 5001 — host audio stream
        TCP 5002 — idle-client invite listener
    -->
    <ComponentGroup Id="AppFirewall" Directory="INSTALLFOLDER">
      <Component Id="AppFirewallRules" Guid="7E4D2F11-19B8-4F9F-9A0D-33B1C2F1B302" KeyPath="yes">
        <RegistryValue Root="HKLM" Key="Software\LiveStreamSound" Name="firewall"
                       Type="integer" Value="1" />
        <fw:FirewallException Id="LSS_TCP_Control"
                              Name="LiveStreamSound (TCP Control)"
                              Protocol="tcp"
                              Port="5000"
                              Scope="localSubnet"
                              Profile="all" />
        <fw:FirewallException Id="LSS_UDP_Audio"
                              Name="LiveStreamSound (UDP Audio)"
                              Protocol="udp"
                              Port="5001"
                              Scope="localSubnet"
                              Profile="all" />
        <fw:FirewallException Id="LSS_TCP_Invite"
                              Name="LiveStreamSound (TCP Invite)"
                              Protocol="tcp"
                              Port="5002"
                              Scope="localSubnet"
                              Profile="all" />
      </Component>
    </ComponentGroup>

    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />
  </Package>
</Wix>
