<ui:FluentWindow x:Class="LiveStreamSound.Host.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:LiveStreamSound.Host.ViewModels"
                 xmlns:conv="clr-namespace:LiveStreamSound.Host.Converters"
                 xmlns:loc="clr-namespace:LiveStreamSound.Shared.Localization;assembly=LiveStreamSound.Shared"
                 Title="LiveStreamSound — Host"
                 Width="1100" Height="720"
                 MinWidth="800" MinHeight="500"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <conv:QualityLevelToBrushConverter x:Key="QualityBrush" />
        <conv:QualityLevelToLocalizedStringConverter x:Key="QualityLabel" />
        <conv:LogLevelToBrushConverter x:Key="LogBrush" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Inverted="True" />
        <conv:BoolInverterConverter x:Key="BoolInv" />
        <conv:BoolToBrushConverter x:Key="AudioFlowingBrush" />
        <conv:IntToVisibilityConverter x:Key="CountEmptyToVis" VisibleWhenZero="True" />
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding [AppName.Host], Source={x:Static loc:Loc.Instance}, Mode=OneWay}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Speaker232" Margin="0,0,8,0" />
                    <TextBlock Text="LiveStreamSound" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Session header bar -->
        <Border Grid.Row="1" Padding="16,12" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon PlayCircle24}"
                               Content="{Binding [Host.StartSession], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding StartSessionCommand}"
                               Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVisInv}}" />
                    <ui:Button Appearance="Danger" Icon="{ui:SymbolIcon RecordStop24}"
                               Content="{Binding [Host.StopSession], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding StopSessionCommand}"
                               Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}" />

                    <StackPanel Margin="24,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding [Host.SessionCode], Source={x:Static loc:Loc.Instance}}"
                                   Opacity="0.7" FontSize="11"/>
                        <TextBlock Text="{Binding FormattedSessionCode}" FontSize="40" FontWeight="Bold"
                                   FontFamily="Consolas"/>
                    </StackPanel>

                    <StackPanel Margin="24,0,0,0" VerticalAlignment="Center"
                                Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding [Host.HostIp], Source={x:Static loc:Loc.Instance}}"
                                   Opacity="0.7" FontSize="11"/>
                        <TextBlock FontSize="16" FontFamily="Consolas">
                            <Run Text="{Binding HostIp, Mode=OneWay}" />:<Run Text="{Binding ControlPort, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </StackPanel>

                <!-- QR -->
                <Border Grid.Column="1" HorizontalAlignment="Right" Margin="0,0,24,0"
                        Visibility="{Binding IsSessionActive, Converter={StaticResource BoolToVis}}"
                        CornerRadius="8" Background="White" Padding="6">
                    <Image Source="{Binding QrCode}" Width="96" Height="96"/>
                </Border>

                <!-- Global actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button Icon="{ui:SymbolIcon LocalLanguage24}"
                               ToolTip="{Binding [Language], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding ToggleLanguageCommand}"
                               Content="{Binding [Language], Source={x:Static loc:Loc.Instance}}"
                               Margin="0,0,8,0"/>
                    <ui:Button Icon="{ui:SymbolIcon DarkTheme24}"
                               ToolTip="{Binding [Theme], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding ToggleThemeCommand}"
                               Margin="0,0,8,0"/>
                    <ui:Button Icon="{ui:SymbolIcon QuestionCircle24}"
                               ToolTip="{Binding [Help], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding ToggleHelpCommand}"
                               Margin="0,0,8,0"/>
                    <ui:Button Icon="{ui:SymbolIcon DocumentError24}"
                               ToolTip="{Binding [Log], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding ToggleLogCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main: client groups + side panels -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Client list -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="16">
                <StackPanel>
                    <ui:InfoBar IsClosable="False"
                                Title="{Binding [Host.Status.Idle], Source={x:Static loc:Loc.Instance}}"
                                Severity="Informational"
                                IsOpen="{Binding IsSessionActive, Converter={StaticResource BoolInv}}" />
                    <ui:InfoBar IsClosable="False"
                                Title="{Binding [Host.Status.Running], Source={x:Static loc:Loc.Instance}}"
                                Severity="Success"
                                IsOpen="{Binding IsSessionActive}" />
                    <ui:InfoBar IsClosable="True"
                                Title="{Binding StartupErrorTitle}"
                                Message="{Binding StartupErrorBody}"
                                Severity="Error"
                                Margin="0,8,0,0"
                                IsOpen="{Binding HasStartupError, Mode=TwoWay}" />

                    <TextBlock Margin="0,16,0,0" Opacity="0.6"
                               Visibility="{Binding ClientGroups.Count, Converter={StaticResource CountEmptyToVis}}"
                               Text="{Binding [Host.NoClients], Source={x:Static loc:Loc.Instance}}"/>

                    <ItemsControl ItemsSource="{Binding ClientGroups}" Margin="0,16,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ClientGroupViewModel}">
                                <Expander IsExpanded="True" Margin="0,0,0,12">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold" FontSize="16"/>
                                            <TextBlock Margin="8,0,0,0" Opacity="0.6">
                                                (<Run Text="{Binding Clients.Count, Mode=OneWay}"/>)
                                            </TextBlock>
                                        </StackPanel>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding Clients}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:ClientViewModel}">
                                                <ui:Card Margin="0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Quality dot -->
                                                        <Ellipse Grid.Column="0" Grid.Row="0" Width="14" Height="14"
                                                                 VerticalAlignment="Center" Margin="0,0,12,0"
                                                                 Fill="{Binding Quality.Level, Converter={StaticResource QualityBrush}}"/>

                                                        <!-- Name + room -->
                                                        <StackPanel Grid.Column="1" Grid.Row="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                                            <TextBlock Opacity="0.6" FontSize="11">
                                                                <Run Text="{Binding RawHostname, Mode=OneWay}" /> •
                                                                <Run Text="{Binding Quality.Level, Converter={StaticResource QualityLabel}, Mode=OneWay}" /> •
                                                                <Run Text="{Binding Quality.RoundTripMs, StringFormat={}{0} ms RTT, Mode=OneWay}" />
                                                            </TextBlock>
                                                        </StackPanel>

                                                        <!-- Actions -->
                                                        <StackPanel Grid.Column="2" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <ui:ToggleSwitch IsChecked="{Binding IsMuted}"
                                                                             OnContent="{Binding [Host.Mute], Source={x:Static loc:Loc.Instance}}"
                                                                             OffContent="{Binding [Host.Mute], Source={x:Static loc:Loc.Instance}}"
                                                                             Margin="0,0,8,0"/>
                                                            <ui:Button Icon="{ui:SymbolIcon DeleteDismiss24}"
                                                                       Appearance="Danger"
                                                                       Command="{Binding KickCommand}"/>
                                                        </StackPanel>

                                                        <!-- Volume + device row -->
                                                        <Grid Grid.Column="1" Grid.Row="1" Margin="0,12,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Grid.Column="0" Text="{Binding [Host.Volume], Source={x:Static loc:Loc.Instance}}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <Slider Grid.Column="1" Minimum="0" Maximum="1" Value="{Binding Volume}" VerticalAlignment="Center"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding Volume, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="8,0"/>
                                                            <ComboBox Grid.Column="3" ItemsSource="{Binding AvailableDevices}"
                                                                      DisplayMemberPath="Name" SelectedValuePath="Id"
                                                                      SelectedValue="{Binding CurrentDeviceId, Mode=TwoWay}"
                                                                      MinWidth="200" Margin="16,0,0,0"/>
                                                        </Grid>

                                                        <!-- Issue banner -->
                                                        <Border Grid.ColumnSpan="3" Grid.Row="2" Margin="0,8,0,0"
                                                                CornerRadius="6" Padding="10,8"
                                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                                                                Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold"/>
                                                                <TextBlock Text="{Binding PrimaryIssueBody}" TextWrapping="Wrap" Opacity="0.8"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </ui:Card>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>

            <!-- Help panel (right side, collapsible) -->
            <Border Grid.Column="1" Width="360"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Padding="16"
                    Visibility="{Binding IsHelpOpen, Converter={StaticResource BoolToVis}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="{Binding [HelpHost.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20" FontWeight="SemiBold"/>
                            <ui:Button Icon="{ui:SymbolIcon DismissCircle24}" HorizontalAlignment="Right"
                                       Command="{Binding ToggleHelpCommand}" Appearance="Transparent"/>
                        </Grid>
                        <TextBlock Margin="0,16,0,4" TextWrapping="Wrap" Text="{Binding [HelpHost.Step1], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpHost.Step2], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpHost.Step3], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpHost.Step4], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpHost.Step5], Source={x:Static loc:Loc.Instance}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Log panel -->
            <Border Grid.Column="1" Width="480"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Padding="16"
                    Visibility="{Binding IsLogOpen, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <TextBlock Text="{Binding [Log], Source={x:Static loc:Loc.Instance}}"
                                   FontSize="20" FontWeight="SemiBold"/>
                        <ui:Button Icon="{ui:SymbolIcon DismissCircle24}" HorizontalAlignment="Right"
                                   Command="{Binding ToggleLogCommand}" Appearance="Transparent"/>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}"
                                   Content="{Binding [LogOpenFolder], Source={x:Static loc:Loc.Instance}}"
                                   Command="{Binding OpenLogFolderCommand}"
                                   Margin="0,0,8,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Broom24}"
                                   Content="{Binding [LogClear], Source={x:Static loc:Loc.Instance}}"
                                   Command="{Binding ClearLogViewCommand}"/>
                    </StackPanel>
                    <ListView Grid.Row="2" ItemsSource="{Binding LogEntries}" FontFamily="Consolas" FontSize="11">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" Opacity="0.5" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Level}" Margin="0,0,8,0"
                                               Foreground="{Binding Level, Converter={StaticResource LogBrush}}"/>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap">
                                        <Run Text="{Binding Category, Mode=OneWay}" FontWeight="SemiBold"/>: <Run Text="{Binding Message, Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" Padding="12,6"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0"
                         Fill="{Binding AudioFlowing, Converter={StaticResource AudioFlowingBrush}}" />
                <TextBlock Text="{Binding [Host.CapturingAudio], Source={x:Static loc:Loc.Instance}}"
                           Visibility="{Binding AudioFlowing, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding [Host.NoAudio], Source={x:Static loc:Loc.Instance}}"
                           Visibility="{Binding AudioFlowing, Converter={StaticResource BoolToVisInv}}"
                           Opacity="0.6"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
