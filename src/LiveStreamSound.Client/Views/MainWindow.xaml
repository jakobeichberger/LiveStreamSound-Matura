<ui:FluentWindow x:Class="LiveStreamSound.Client.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:conv="clr-namespace:LiveStreamSound.Client.Converters"
                 xmlns:vm="clr-namespace:LiveStreamSound.Client.ViewModels"
                 xmlns:loc="clr-namespace:LiveStreamSound.Shared.Localization;assembly=LiveStreamSound.Shared"
                 Title="LiveStreamSound — Client"
                 Width="780" Height="680"
                 MinWidth="600" MinHeight="480"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <conv:QualityLevelToBrushConverter x:Key="QualityBrush"/>
        <conv:QualityLevelToLocalizedStringConverter x:Key="QualityLabel"/>
        <conv:LogLevelToBrushConverter x:Key="LogBrush"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Inverted="True"/>
        <conv:StringToVisibilityConverter x:Key="HasStringToVis"/>
        <conv:StringHasContentConverter x:Key="HasString"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0"
                     Title="{Binding [AppName.Client], Source={x:Static loc:Loc.Instance}, Mode=OneWay}">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Headphones24" Margin="0,0,8,0"/>
                    <TextBlock Text="LiveStreamSound" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <Border Grid.Row="1" Padding="12,8" Background="{DynamicResource ControlFillColorDefaultBrush}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Icon="{ui:SymbolIcon LocalLanguage24}"
                           Content="{Binding [Language], Source={x:Static loc:Loc.Instance}}"
                           Command="{Binding ToggleLanguageCommand}" Margin="0,0,8,0"/>
                <ui:Button Icon="{ui:SymbolIcon DarkTheme24}"
                           Command="{Binding ToggleThemeCommand}" Margin="0,0,8,0"
                           ToolTip="{Binding [Theme], Source={x:Static loc:Loc.Instance}}"/>
                <ui:Button Icon="{ui:SymbolIcon QuestionCircle24}"
                           Command="{Binding ToggleHelpCommand}" Margin="0,0,8,0"
                           ToolTip="{Binding [Help], Source={x:Static loc:Loc.Instance}}"/>
                <ui:Button Icon="{ui:SymbolIcon DocumentError24}"
                           Command="{Binding ToggleLogCommand}"
                           ToolTip="{Binding [Log], Source={x:Static loc:Loc.Instance}}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Idle (not connected) view -->
            <ScrollViewer Grid.Column="0" Padding="24"
                          VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding IsIdle, Converter={StaticResource BoolToVis}}">
                <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding [Client.PickHost], Source={x:Static loc:Loc.Instance}}"
                               FontWeight="SemiBold" FontSize="16" Margin="0,0,0,12"/>

                    <!-- Discovered hosts list -->
                    <ItemsControl ItemsSource="{Binding DiscoveredHosts}"
                                  Visibility="{Binding DiscoveredHosts.Count, Converter={StaticResource HasStringToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DiscoveredHostViewModel}">
                                <ui:CardAction Margin="0,0,0,8"
                                               Command="{Binding DataContext.SelectDiscoveredHostCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                               CommandParameter="{Binding}"
                                               Icon="{ui:SymbolIcon Speaker232}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding DisplayAddress}" Opacity="0.6" FontSize="11"/>
                                    </StackPanel>
                                </ui:CardAction>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="{Binding [Client.NoHostsFound], Source={x:Static loc:Loc.Instance}}"
                               Opacity="0.7" Margin="0,0,0,12" TextWrapping="Wrap"
                               Visibility="{Binding DiscoveredHosts.Count, Converter={StaticResource BoolToVisInv}}"/>

                    <!-- Manual IP -->
                    <TextBlock Text="{Binding [Client.ManualEntry], Source={x:Static loc:Loc.Instance}}"
                               FontWeight="SemiBold" Margin="0,16,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:TextBox Grid.Column="0" PlaceholderText="192.168.x.x"
                                    Text="{Binding ManualHost, UpdateSourceTrigger=PropertyChanged}"
                                    Margin="0,0,8,0"/>
                        <ui:TextBox Grid.Column="1" Width="100"
                                    Text="{Binding ManualPort, UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>

                    <!-- Code -->
                    <TextBlock Text="{Binding [Client.Code], Source={x:Static loc:Loc.Instance}}" Margin="0,8,0,4"/>
                    <ui:TextBox Text="{Binding SessionCode, UpdateSourceTrigger=PropertyChanged}"
                                FontSize="22" FontFamily="Consolas" MaxLength="6"
                                Margin="0,0,0,16"/>

                    <!-- Name -->
                    <TextBlock Text="{Binding [Client.DisplayName], Source={x:Static loc:Loc.Instance}}" Margin="0,0,0,4"/>
                    <ui:TextBox Text="{Binding DisplayName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16"/>

                    <!-- Output device -->
                    <TextBlock Text="{Binding [Client.OutputDevice], Source={x:Static loc:Loc.Instance}}" Margin="0,0,0,4"/>
                    <ComboBox ItemsSource="{Binding OutputDevices}"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectedValue="{Binding SelectedOutputDeviceId}"
                              Margin="0,0,0,20"/>

                    <ui:Button Appearance="Primary" Icon="{ui:SymbolIcon PlugConnected24}"
                               Content="{Binding [Connect], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding ConnectCommand}"
                               IsEnabled="{Binding CanConnect}"
                               HorizontalAlignment="Left"/>

                    <ui:InfoBar Title="{Binding ConnectionError}"
                                Message="{Binding ConnectionErrorBody}"
                                Severity="Error"
                                IsClosable="False"
                                Margin="0,16,0,0"
                                IsOpen="{Binding ConnectionError, Converter={StaticResource HasString}}"
                                Visibility="{Binding ConnectionError, Converter={StaticResource HasStringToVis}}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Connecting overlay -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsConnecting, Converter={StaticResource BoolToVis}}">
                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" HorizontalAlignment="Center"/>
                <TextBlock Text="{Binding [Client.Connecting], Source={x:Static loc:Loc.Instance}}"
                           Margin="0,16,0,0" FontSize="16" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Connected view -->
            <Grid Grid.Column="0" Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
                <StackPanel MaxWidth="520" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Border HorizontalAlignment="Center" Margin="0,0,0,16"
                            Width="88" Height="88" CornerRadius="44"
                            Background="#16A34A">
                        <ui:SymbolIcon Symbol="Headphones32" Foreground="White" Width="48" Height="48"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding [Client.Connected.Title], Source={x:Static loc:Loc.Instance}}"
                               FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding [Client.Connected.Subtitle], Source={x:Static loc:Loc.Instance}}"
                               Opacity="0.7" HorizontalAlignment="Center" TextWrapping="Wrap" Margin="0,8,0,24"
                               TextAlignment="Center"/>

                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                            CornerRadius="8" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock Text="{Binding [Client.Connected.Host], Source={x:Static loc:Loc.Instance}}"
                                           Width="130" Opacity="0.7"/>
                                <TextBlock Text="{Binding ConnectedHostDisplay}" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding [Client.OutputDevice], Source={x:Static loc:Loc.Instance}}"
                                           Width="130" Opacity="0.7" VerticalAlignment="Center"/>
                                <ComboBox MinWidth="280"
                                          ItemsSource="{Binding OutputDevices}"
                                          DisplayMemberPath="Name" SelectedValuePath="Id"
                                          SelectedValue="{Binding SelectedOutputDeviceId}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ui:Button Appearance="Secondary"
                               Icon="{ui:SymbolIcon PlugDisconnected24}"
                               Content="{Binding [Disconnect], Source={x:Static loc:Loc.Instance}}"
                               Command="{Binding DisconnectCommand}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Help panel -->
            <Border Grid.Column="1" Width="360" Padding="16"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Visibility="{Binding IsHelpOpen, Converter={StaticResource BoolToVis}}">
                <ScrollViewer>
                    <StackPanel>
                        <Grid>
                            <TextBlock Text="{Binding [HelpClient.Title], Source={x:Static loc:Loc.Instance}}"
                                       FontSize="20" FontWeight="SemiBold"/>
                            <ui:Button Icon="{ui:SymbolIcon DismissCircle24}" HorizontalAlignment="Right"
                                       Command="{Binding ToggleHelpCommand}" Appearance="Transparent"/>
                        </Grid>
                        <TextBlock Margin="0,16,0,4" TextWrapping="Wrap" Text="{Binding [HelpClient.Step1], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpClient.Step2], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpClient.Step3], Source={x:Static loc:Loc.Instance}}"/>
                        <TextBlock Margin="0,4" TextWrapping="Wrap" Text="{Binding [HelpClient.Step4], Source={x:Static loc:Loc.Instance}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Log panel -->
            <Border Grid.Column="1" Width="480" Padding="16"
                    BorderThickness="1,0,0,0"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    Visibility="{Binding IsLogOpen, Converter={StaticResource BoolToVis}}"
                    Panel.ZIndex="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0">
                        <TextBlock Text="{Binding [Log], Source={x:Static loc:Loc.Instance}}"
                                   FontSize="20" FontWeight="SemiBold"/>
                        <ui:Button Icon="{ui:SymbolIcon DismissCircle24}" HorizontalAlignment="Right"
                                   Command="{Binding ToggleLogCommand}" Appearance="Transparent"/>
                    </Grid>
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                        <ui:Button Icon="{ui:SymbolIcon FolderOpen24}"
                                   Content="{Binding [LogOpenFolder], Source={x:Static loc:Loc.Instance}}"
                                   Command="{Binding OpenLogFolderCommand}" Margin="0,0,8,0"/>
                        <ui:Button Icon="{ui:SymbolIcon Broom24}"
                                   Content="{Binding [LogClear], Source={x:Static loc:Loc.Instance}}"
                                   Command="{Binding ClearLogViewCommand}"/>
                    </StackPanel>
                    <ListView Grid.Row="2" ItemsSource="{Binding LogEntries}" FontFamily="Consolas" FontSize="11">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat=HH:mm:ss}" Opacity="0.5" Margin="0,0,8,0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Level}" Margin="0,0,8,0"
                                               Foreground="{Binding Level, Converter={StaticResource LogBrush}}"/>
                                    <TextBlock Grid.Column="2" TextWrapping="Wrap">
                                        <Run Text="{Binding Category, Mode=OneWay}" FontWeight="SemiBold"/>: <Run Text="{Binding Message, Mode=OneWay}"/>
                                    </TextBlock>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom status bar: only meaningful when connected -->
        <Border Grid.Row="3" Padding="12,10"
                BorderThickness="0,1,0,0"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                Visibility="{Binding IsConnected, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Ellipse Grid.Column="0" Grid.Row="0" Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,8,0"
                         Fill="{Binding Quality.Level, Converter={StaticResource QualityBrush}}"/>
                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Quality.Level, Converter={StaticResource QualityLabel}}" FontWeight="SemiBold"/>
                    <TextBlock Margin="12,0,0,0" Opacity="0.7">
                        <Run Text="{Binding Quality.RoundTripMs, Mode=OneWay}"/> ms •
                        <Run Text="{Binding Quality.PacketLossPercent, StringFormat={}{0:F1}%, Mode=OneWay}"/> loss •
                        Buffer <Run Text="{Binding Quality.BufferedMs, Mode=OneWay}"/> ms
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1" Margin="0,8,0,0"
                        CornerRadius="6" Padding="10,8"
                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        Visibility="{Binding HasIssues, Converter={StaticResource BoolToVis}}">
                    <StackPanel>
                        <TextBlock Text="{Binding PrimaryIssueTitle}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PrimaryIssueBody}" TextWrapping="Wrap" Opacity="0.85"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
