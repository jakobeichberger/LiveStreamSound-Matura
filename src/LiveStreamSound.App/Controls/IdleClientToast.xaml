<UserControl x:Class="LiveStreamSound.App.Controls.IdleClientToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:loc="clr-namespace:LiveStreamSound.Shared.Localization;assembly=LiveStreamSound.Shared"
             xmlns:conv="clr-namespace:LiveStreamSound.App.Converters"
             xmlns:vm="clr-namespace:LiveStreamSound.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:IdleClientNotificationViewModel}"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             Width="340" MinHeight="78" Margin="0,0,0,12"
             RenderTransformOrigin="0.5,0.5">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Inverted="True"/>
    </UserControl.Resources>

    <UserControl.RenderTransform>
        <TransformGroup>
            <!-- Slide-in (X: 320 → 0) -->
            <TranslateTransform x:Name="SlideTransform" X="320"/>
            <!-- Breath-pulse (1.0 ↔ 1.015) — set on .Loaded -->
            <ScaleTransform x:Name="BreathTransform" ScaleX="1" ScaleY="1"/>
        </TransformGroup>
    </UserControl.RenderTransform>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="UserControl.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <!-- Slide-in animation -->
                    <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                     Storyboard.TargetProperty="X"
                                     From="320" To="0"
                                     Duration="0:0:0.45">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ToastBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1"
                                     Duration="0:0:0.35"/>

                    <!-- Breath: subtle scale pulse, infinite + autoreverse, sinusoidal -->
                    <DoubleAnimation Storyboard.TargetName="BreathTransform"
                                     Storyboard.TargetProperty="ScaleX"
                                     From="1.0" To="1.015"
                                     BeginTime="0:0:0.6"
                                     Duration="0:0:1.6"
                                     RepeatBehavior="Forever"
                                     AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="BreathTransform"
                                     Storyboard.TargetProperty="ScaleY"
                                     From="1.0" To="1.015"
                                     BeginTime="0:0:0.6"
                                     Duration="0:0:1.6"
                                     RepeatBehavior="Forever"
                                     AutoReverse="True">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Border x:Name="ToastBorder"
            CornerRadius="14"
            Padding="14,12"
            Opacity="0"
            BorderThickness="1"
            BorderBrush="{DynamicResource AccentControlElevationBorderBrush}"
            Background="{DynamicResource SolidBackgroundFillColorSecondaryBrush}">
        <Border.Effect>
            <!-- Soft shadow gives it the "floating above the dashboard" feel
                 without competing with the actual dashboard for attention. -->
            <DropShadowEffect Color="Black" BlurRadius="18" ShadowDepth="2" Opacity="0.18"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Avatar circle with the room's number/initial.
                 Accent gradient gives it personality without being loud. -->
            <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,12,0" VerticalAlignment="Center">
                <Ellipse>
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="{DynamicResource SystemAccentColorLight2}" Offset="0"/>
                            <GradientStop Color="{DynamicResource SystemAccentColorPrimary}" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <TextBlock Text="{Binding Initial}"
                           FontWeight="Bold" FontSize="15"
                           Foreground="White"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <!-- Body -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Sparkle24" FontSize="13"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Margin="0,2,0,0" FontSize="11" Opacity="0.7"
                           Text="{Binding [Notification.IdleClient.Subtitle], Source={x:Static loc:Loc.Instance}}"
                           Visibility="{Binding StatusText, Converter={StaticResource BoolToVisInv}}"/>
                <TextBlock Margin="0,2,0,0" FontSize="11"
                           Text="{Binding StatusText}"
                           Visibility="{Binding StatusText, Converter={StaticResource BoolToVis}}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Opacity" Value="0.8"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasError}" Value="True">
                                    <Setter Property="Foreground" Value="{DynamicResource SystemFillColorCriticalBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <!-- Add + dismiss buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <ui:Button Appearance="Primary" Width="44" Height="36"
                           Padding="0" Margin="0,0,6,0"
                           Icon="{ui:SymbolIcon Add24}"
                           ToolTip="{Binding [Notification.IdleClient.AddTooltip], Source={x:Static loc:Loc.Instance}}"
                           AutomationProperties.Name="{Binding [Notification.IdleClient.AddTooltip], Source={x:Static loc:Loc.Instance}}"
                           Command="{Binding InviteCommand}"
                           Visibility="{Binding IsInviting, Converter={StaticResource BoolToVisInv}}"/>
                <ui:ProgressRing IsIndeterminate="True" Width="22" Height="22"
                                 Margin="11,0,17,0"
                                 Visibility="{Binding IsInviting, Converter={StaticResource BoolToVis}}"/>
                <ui:Button Width="32" Height="36"
                           Padding="0"
                           Appearance="Transparent"
                           Icon="{ui:SymbolIcon Dismiss20}"
                           ToolTip="{Binding [Notification.IdleClient.DismissTooltip], Source={x:Static loc:Loc.Instance}}"
                           AutomationProperties.Name="{Binding [Notification.IdleClient.DismissTooltip], Source={x:Static loc:Loc.Instance}}"
                           Command="{Binding DismissCommand}"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
