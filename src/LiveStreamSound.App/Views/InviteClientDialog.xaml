<ui:FluentWindow x:Class="LiveStreamSound.App.Views.InviteClientDialog"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:LiveStreamSound.App.ViewModels"
                 xmlns:conv="clr-namespace:LiveStreamSound.App.Converters"
                 xmlns:loc="clr-namespace:LiveStreamSound.Shared.Localization;assembly=LiveStreamSound.Shared"
                 Title="{Binding [Invite.DialogTitle], Source={x:Static loc:Loc.Instance}}"
                 Width="520" Height="560"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="CanResize"
                 MinWidth="420" MinHeight="420"
                 ShowInTaskbar="False"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisInv" Inverted="True"/>
        <conv:StringToVisibilityConverter x:Key="HasStringToVis"/>
        <conv:IntToVisibilityConverter x:Key="CountEmptyToVis" VisibleWhenZero="True"/>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="{Binding [Invite.DialogTitle], Source={x:Static loc:Loc.Instance}}"/>

        <ScrollViewer Grid.Row="1" Padding="24,12,24,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="{Binding [Invite.IdleClients], Source={x:Static loc:Loc.Instance}}"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <TextBlock Text="{Binding [Invite.NoIdleClients], Source={x:Static loc:Loc.Instance}}"
                           Opacity="0.65" TextWrapping="Wrap"
                           Visibility="{Binding Clients.Count, Converter={StaticResource CountEmptyToVis}}"/>

                <ItemsControl ItemsSource="{Binding Clients}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:IdleClientViewModel}">
                            <ui:CardAction Margin="0,0,0,8"
                                           Icon="{ui:SymbolIcon Headphones24}"
                                           Command="{Binding DataContext.InviteDiscoveredCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding}">
                                <StackPanel>
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DisplayAddress}" Opacity="0.6" FontSize="11"/>
                                </StackPanel>
                            </ui:CardAction>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <TextBlock Text="{Binding [Invite.ManualTarget], Source={x:Static loc:Loc.Instance}}"
                           FontWeight="SemiBold" Margin="0,20,0,8"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox Grid.Column="0" PlaceholderText="192.168.x.x"
                                Text="{Binding ManualIp, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0"/>
                    <ui:TextBox Grid.Column="1" Width="80"
                                Text="{Binding ManualPort, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0"/>
                    <ui:Button Grid.Column="2"
                               Icon="{ui:SymbolIcon Send24}"
                               Content="{Binding [Invite.InvitationButton], Source={x:Static loc:Loc.Instance}}"
                               Appearance="Primary"
                               Command="{Binding InviteManualCommand}"
                               IsEnabled="{Binding IsSending, Converter={StaticResource BoolToVisInv}}"/>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="24,12" Margin="0,16,0,0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource HasStringToVis}}">
            <StackPanel Orientation="Horizontal">
                <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"
                                 Visibility="{Binding IsSending, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,24,16">
            <ui:Button Content="{Binding [Invite.Cancel], Source={x:Static loc:Loc.Instance}}"
                       Click="OnClose"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
