<ui:FluentWindow x:Class="LiveStreamSound.App.Views.RoleSelectionWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 xmlns:vm="clr-namespace:LiveStreamSound.App.ViewModels"
                 xmlns:loc="clr-namespace:LiveStreamSound.Shared.Localization;assembly=LiveStreamSound.Shared"
                 Title="LiveStreamSound"
                 Width="900" Height="620"
                 MinWidth="700" MinHeight="500"
                 WindowStartupLocation="CenterScreen"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <ui:FluentWindow.DataContext>
        <vm:RoleSelectionViewModel/>
    </ui:FluentWindow.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ui:TitleBar Grid.Row="0" Title="LiveStreamSound">
            <ui:TitleBar.Header>
                <StackPanel Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Speaker232" Margin="0,0,8,0"/>
                    <TextBlock Text="LiveStreamSound" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- Header -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,24,0,32">
            <TextBlock Text="{Binding [App.Welcome], Source={x:Static loc:Loc.Instance}}"
                       FontSize="14" Opacity="0.6" HorizontalAlignment="Center"/>
            <TextBlock Text="{Binding [App.ChooseRole], Source={x:Static loc:Loc.Instance}}"
                       FontSize="32" FontWeight="SemiBold" Margin="0,4,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Two cards -->
        <Grid Grid.Row="2" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- SEND card -->
            <ui:CardAction Grid.Column="0" Height="320"
                           Command="{Binding ChooseHostCommand}"
                           AutomationProperties.Name="{Binding [App.Role.SendTitle], Source={x:Static loc:Loc.Instance}}"
                           AutomationProperties.HelpText="{Binding [App.Role.SendSubtitle], Source={x:Static loc:Loc.Instance}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="96" Height="96" CornerRadius="48"
                            Background="#2563EB" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Speaker232" Foreground="White" FontSize="52"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding [App.Role.SendTitle], Source={x:Static loc:Loc.Instance}}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding [App.Role.SendSubtitle], Source={x:Static loc:Loc.Instance}}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="16,12,16,0" Opacity="0.75"
                               MaxWidth="240"/>
                </StackPanel>
            </ui:CardAction>

            <!-- RECEIVE card -->
            <ui:CardAction Grid.Column="2" Height="320"
                           Command="{Binding ChooseClientCommand}"
                           AutomationProperties.Name="{Binding [App.Role.ReceiveTitle], Source={x:Static loc:Loc.Instance}}"
                           AutomationProperties.HelpText="{Binding [App.Role.ReceiveSubtitle], Source={x:Static loc:Loc.Instance}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Border Width="96" Height="96" CornerRadius="48"
                            Background="#16A34A" Margin="0,0,0,20">
                        <ui:SymbolIcon Symbol="Headphones32" Foreground="White" FontSize="52"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding [App.Role.ReceiveTitle], Source={x:Static loc:Loc.Instance}}"
                               FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding [App.Role.ReceiveSubtitle], Source={x:Static loc:Loc.Instance}}"
                               TextWrapping="Wrap" TextAlignment="Center"
                               Margin="16,12,16,0" Opacity="0.75"
                               MaxWidth="240"/>
                </StackPanel>
            </ui:CardAction>
        </Grid>

        <!-- Bottom action bar -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"
                    Margin="0,16,0,24">
            <ui:Button Icon="{ui:SymbolIcon LocalLanguage24}"
                       Content="{Binding [Language], Source={x:Static loc:Loc.Instance}}"
                       ToolTip="{Binding [A11y.LanguageToggle], Source={x:Static loc:Loc.Instance}}"
                       AutomationProperties.Name="{Binding [A11y.LanguageToggle], Source={x:Static loc:Loc.Instance}}"
                       Command="{Binding ToggleLanguageCommand}" Margin="0,0,8,0"/>
            <ui:Button Icon="{ui:SymbolIcon DarkTheme24}"
                       ToolTip="{Binding [A11y.ThemeToggle], Source={x:Static loc:Loc.Instance}}"
                       AutomationProperties.Name="{Binding [A11y.ThemeToggle], Source={x:Static loc:Loc.Instance}}"
                       Command="{Binding ToggleThemeCommand}"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
